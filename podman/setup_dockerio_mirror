#!/bin/bash
# Setup docker.io registry mirror
# Usage: setup_dockerio_mirror <mirror_url>
# Example: setup_dockerio_mirror https://mirror.gcr.io

MIRROR_URL="$1"

if [ -z "$MIRROR_URL" ]; then
    echo "Usage: setup_dockerio_mirror <mirror_url>"
    exit 1
fi

cat > /etc/containers/registries.conf.d/00-docker-mirror.conf << EOF
[[registry]]
prefix = "docker.io"
location = "docker.io"

[[registry.mirror]]
location = "${MIRROR_URL#https://}"
insecure = false
EOF

echo "Configured docker.io mirror: $MIRROR_URL"
