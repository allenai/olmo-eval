#!/bin/bash
# Setup Modal secret with GCP credentials for Artifact Registry access
# Requires:
#   - GOOGLE_APPLICATION_CREDENTIALS env var (file path to JSON key)
#   - MODAL_TOKEN_ID and MODAL_TOKEN_SECRET env vars for Modal auth
#   - MODAL_GCP_SECRET_NAME env var with the secret name to create
#
# This script is idempotent - it will create or update the secret.

set -e

if [ -z "$MODAL_GCP_SECRET_NAME" ]; then
    echo "MODAL_GCP_SECRET_NAME not set, skipping Modal secret setup"
    return 0 2>/dev/null || true  # return when sourced, no-op when executed directly
fi

if [ -z "$GOOGLE_APPLICATION_CREDENTIALS" ]; then
    echo "GOOGLE_APPLICATION_CREDENTIALS not set, skipping Modal secret setup"
    return 0 2>/dev/null || true
fi

if [ -z "$MODAL_TOKEN_ID" ] || [ -z "$MODAL_TOKEN_SECRET" ]; then
    echo "MODAL_TOKEN_ID or MODAL_TOKEN_SECRET not set, skipping Modal secret setup"
    return 0 2>/dev/null || true
fi

echo "Setting up Modal secret '$MODAL_GCP_SECRET_NAME'..."

# Use Python to handle the secret creation - avoids all shell escaping issues
# All output is suppressed to avoid leaking credentials
python3 -c "
import os
import sys
import json
import subprocess
import tempfile

secret_name = os.environ['MODAL_GCP_SECRET_NAME']
creds_path = os.environ['GOOGLE_APPLICATION_CREDENTIALS']

# Read credentials from file
if not os.path.isfile(creds_path):
    print('Error: credentials file not found', file=sys.stderr)
    sys.exit(1)

with open(creds_path) as f:
    json_content = f.read().strip()

# Validate it's valid JSON (don't print the content or error details)
try:
    json.loads(json_content)
except json.JSONDecodeError:
    print('Error: invalid JSON in credentials file', file=sys.stderr)
    sys.exit(1)

# Write JSON to temp file to avoid command line exposure
with tempfile.NamedTemporaryFile(mode='w', suffix='.json', delete=False) as f:
    f.write(json_content)
    temp_path = f.name

try:
    # Modal CLI: modal secret create NAME KEY=@filepath
    # Using @filepath syntax so secret value is not on command line
    result = subprocess.run(
        [sys.executable, '-m', 'modal', 'secret', 'create', secret_name,
         f'SERVICE_ACCOUNT_JSON=@{temp_path}', '--force'],
        capture_output=True,  # Suppress all output to avoid leaking secrets
        text=True,
    )
    if result.returncode != 0:
        # Don't print stderr as it might contain secret info
        print('Error: failed to create Modal secret', file=sys.stderr)
        sys.exit(1)
finally:
    os.unlink(temp_path)
"

echo "Modal secret '$MODAL_GCP_SECRET_NAME' configured successfully"
